# Router instance settings for reference-backed public templates.
MODEL_CHECKER_ROUTER_ROOT=/path/to/codex-router
MODEL_CHECKER_ROUTER_ENV_FILE=/path/to/codex-router/router.env
MODEL_CHECKER_NODE_BIN=node

# Generic OpenAI-compatible target template.
MODEL_CHECKER_TARGET_BASE_URL=https://provider.example/v1
MODEL_CHECKER_TARGET_API_KEY=replace-me

# Optional provider-specific example kept for historical sample configs.
MODEL_CHECKER_ASKMANY_BASE_URL=https://your-askmanyai-endpoint.example
ASKMANY_API_KEY=replace-me
